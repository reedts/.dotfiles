[colors]
background = #121212
background-trans = #ee121212
background-active-trans = #ee4699AF
background-mode-trans = #eeF92672
background-enable-trans = #ee84c00c
background-disable-trans = #eeF92672
foreground = #F8F8F2
foreground-inactive = #9999AA

light_cyan = #66D9EF
light_grey = #9999AA
light_green = #80FF00
blue = #4699AF
red = #F92672
orange = #D75F00

[bar/primary]
width = 100%
height = 27
offset-x = 0
offset-y = 0
;radius = 6.0
fixed-center = false

background = ${colors.background-trans}
foreground = ${colors.foreground}

line-size = 3
;line-color = #f00

border-size = 0
;border-color = #00000000

padding-left = 0
padding-right = 1

module-margin-left = 0
module-margin-right = 1

font-0 = Droid Sans Mono:size=8;1
font-1 = FontAwesome:size=10;1

modules-left = i3
modules-center = xwindow
modules-right = wlan eth battery date powermenu

tray-position = right
tray-padding = 2
;tray-transparent = true
tray-background = #121212

;wm-restack = bspwm
;wm-restack = i3

;override-redirect = true

;scroll-up = bspwm-desknext
;scroll-down = bspwm-deskprev

;scroll-up = i3wm-wsnext
;scroll-down = i3wm-wsprev

[module/xwindow]
type = internal/xwindow
label = %title:0:30:...%
format-padding = 2

[module/i3]
type = internal/i3
format = <label-state> <label-mode>

label-focused = %name%
label-focused-background = ${colors.background-active-trans}
label-focused-underline= ${colors.light_cyan}
label-focused-padding = 2

label-occupied = %name%
label-occupied-padding = 2

label-urgent = %name%
label-urgent-background = ${colors.red}
label-urgent-padding = 2

label-empty = %name%
label-empty-foreground = ${colors.light_grey}
label-empty-padding = 2

index-sort = true
wrapping-scroll = false

; Only show workspaces on the same output as the bar
pin-workspaces = true

label-mode-padding = 2
label-mode-foreground = ${colors.foreground}
label-mode-background = ${colors.background-mode-trans}

; unfocused = Inactive workspace on any monitor
label-unfocused = %name%
label-unfocused-padding = 2

; visible = Active workspace on unfocused monitor
label-visible = %name%
label-visible-background = ${self.label-focused-background}
label-visible-underline = ${self.label-focused-underline}
label-visible-padding = ${self.label-focused-padding}


[module/cpu]
type = internal/cpu
interval = 2
format-prefix = " "
format-prefix-foreground = ${colors.foreground}
format-underline = ${colors.light_cyan}
label = %percentage%%

[module/memory]
type = internal/memory
interval = 2
format-prefix = " "
format-prefix-foreground = ${colors.foreground}
format-underline = ${colors.light_cyan}
label = %percentage_used%%


[module/eth]
type = internal/network
interface = enp0s25
interval = 3.0

format-connected-padding = 1

format-connected-prefix = " "
label-connected = %local_ip%
;format-connected-background = ${colors.background-enable-trans}
format-connected-underline = ${colors.light_green}
format-connected-prefix-foreground = ${colors.foreground}

;format-disconnected = ${colors.light_grey}
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${colors.red}
;format-disconnected-background = ${colors.background-disable-trans}
;label-disconnected =
;label-disconnected-foreground = ${colors.foreground-alt}

[module/wlan]
type = internal/network
interface = wlp2s0
interval = 3.0

format-connected-padding = 1

format-connected-prefix = "  "
format-connected = <label-connected>
;format-connected-background = ${colors.background-enable-trans}
format-connected-foreground = ${colors.foreground}
format-connected-underline = ${colors.light_green}
label-connected = %essid%

;format-disconnected =
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}

;ramp-signal-0 = 
;ramp-signal-1 = 
;ramp-signal-2 = 
;ramp-signal-3 = 
;ramp-signal-4 = 
;ramp-signal-foreground = ${colors.foreground}

[module/battery]
type = internal/battery
battery = BAT0
adapter = AC
full-at = 80

time-format = %H:%M

label-charging = %percentage%% (%time%)
format-charging-padding = 1
format-charging = <animation-charging> <label-charging>
format-charging-prefix = " "
format-charging-underline = ${colors.light_green}
format-charging-background = ${colors.background-enable-trans}
format-charging-foreground = ${colors.foreground}

label-discharging = ${self.label-charging}
label-discharging-alt = %percentage%% (%time%)
format-discharging-padding = 1
format-discharging = <ramp-capacity> <label-discharging>
format-discharging-underline = ${colors.light_cyan}
;format-discharging-background = ${colors.background-enable-trans}
format-discharging-foreground = ${self.format-charging-foreground}

format-full-prefix = "  "
format-full-padding = 1
format-full-background = ${self.format-charging-background}
format-full-foreground = ${colors.foreground}
format-full-underline = ${self.format-charging-underline}

ramp-capacity-0 = 
ramp-capacity-1 = 
ramp-capacity-2 = 
ramp-capacity-3 = 
ramp-capacity-4 = 
;ramp-capacity-1-foreground = ${colors.red}
ramp-capacity-0-foreground = ${colors.red}
ramp-capacity-foreground = ${colors.foreground}

animation-charging-0 = 
animation-charging-1 = 
animation-charging-2 = 
animation-charging-3 = 
animation-charging-4 = 
animation-charging-foreground = ${colors.foreground}
animation-charging-framerate = 750


[module/date]
type = internal/date
interval = 5

date = "%Y-%m-%d"
date-alt = "%Y-%m-%d"

time = %H:%M
time-alt = %H:%M:%S

;format-prefix = 
format-prefix-foreground = ${colors.foreground}
format-underline = ${colors.blue}


label = %date% %time%


[module/powermenu]
type = custom/menu

format-spacing = 1
format-padding = 1

label-open = 
label-open-foreground = ${colors.blue}
label-close = cancel
label-close-foreground = ${colors.blue}
label-separator = |
label-separator-foreground = ${colors.foreground}

menu-0-0 = reboot
menu-0-0-exec = menu-open-1
menu-0-1 = power off
menu-0-1-exec = menu-open-2

menu-1-0 = cancel
menu-1-0-exec = menu-open-0
menu-1-1 = reboot
menu-1-1-exec = systemctl reboot

menu-2-0 = power off
menu-2-0-exec = systemctl poweroff
menu-2-1 = cancel
menu-2-1-exec = menu-open-0

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over

[global/wm]
margin-top = 0
margin-bottom = 0

; vim:ft=dosini
