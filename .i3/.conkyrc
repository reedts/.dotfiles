out_to_x no
own_window no
out_to_console yes
times_in_seconds yes
background no
update_interval 2.0

mpd_port 6600


TEXT
[
 { "full_text" : "´çÇ ${fs_free}",
       "color" : "${if_match ${fs_used_perc} < 90}\#66D9EF"${else}\#F92672"${endif}
 },

 { "full_text" : "´ç╗ ${acpitemp} ┬░C",
       "color" : "\#66D9EF"
 },

 { "full_text" : "´âĄ ${cpu}%",
       "color" : ${if_match ${cpu} < 80}"\#66D9EF"${else}"\#F92672"${endif}
 },

 { "full_text" : "´âç ${memfree}",
       "color" : ${if_match ${memperc} < 80}"\#66D9EF"${else}"\#F92672"${endif}
 },

 { "full_text" : ${if_up wlp3s0} ${if_match "${addr wlp3s0}"=="No Address"}"´çź ´üľ" ${else} "´çź ${wireless_link_qual_perc wlp3s0}% ${addr wlp3s0}" ${endif},
       "color" : "\#A6E22E" ${else} "´çź ´ü×", "color" : "\#F92672" ${endif}
 },

 { "full_text" : ${if_up enp2s0f1} ${if_match "${addr enp2s0f1}"=="No Address"}"´âĘ ´üľ" ${else} "´âĘ ${addr enp2s0f1}" ${endif},
       "color" : "\#A6E22E" ${else} "´âĘ ´ü×", "color" : "\#F92672"${endif}
 },

 { "full_text" : "${if_match "${acpiacadapter}"=="on-line"}´çŽ${else}${if_match ${battery_percent}<=10}´ëä ${else}${if_match ${battery_percent} <= 25}´ëâ ${else}${if_match ${battery_percent} <= 50}´ëé ${else}${if_match ${battery_percent} <= 75}´ëü ${else}${if_match ${battery_percent} <= 99}´ëÇ ${else}${if_match ${battery_percent}==100}´âž ${endif}${endif}${endif}${endif}${endif}${endif}${endif} ${battery_percent}% (${format_time ${battery_time} "\h:\m"})",
       "color" : "${if_match ${battery_percent} > 20}\#A6E22E"${else}\#F92672"${endif}
 },

 { "full_text" : "${time %d-%m-%Y  %H:%M}",
       "color" : "\#F8F8F2"
 }
],
