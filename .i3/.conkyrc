out_to_x no
own_window no
out_to_console yes
background no
update_interval 5.0
times_in_seconds yes

mpd_port 6600


TEXT
[
 { "full_text" : "´âĄ ${cpu}%",
       "color" : ${if_match ${cpu} < 80}"\#66D9EF" ${else} "\#F92672" ${endif}
 },

 { "full_text" : "´âç ${memfree}",
       "color" : ${if_match ${memperc} < 80}"\#66D9EF" ${else} "\#F92672" ${endif}
 },

 { "full_text" : ${if_up wlp2s0} ${if_match "${addr wlp2s0}"=="No Address"}"´çź ´üľ" ${else} "´çź ${wireless_link_qual_perc wlp2s0}% ${addr wlp2s0}" ${endif},
       "color" : "\#A6E22E" ${else} "´çź ´ü×", "color" : "\#F92672" ${endif}
 },

 { "full_text" : ${if_up enp0s25} ${if_match "${addr enp0s25}"=="No Address"}"´âĘ ´üľ" ${else} "´âĘ ${addr enp0s25}" ${endif},
       "color" : "\#A6E22E" ${else} "´âĘ ´ü×", "color" : "\#F92672"${endif}
 },

 { "full_text" : "${if_match "${acpiacadapter}"=="on-line"}´çŽ ${else}${if_match ${smapi_bat_perc 0}<=10}´ëä ${else}${if_match ${smapi_bat_perc 0}<= 25}´ëâ ${else}${if_match ${smapi_bat_perc 0}<= 40}´ëé ${else}${if_match ${smapi_bat_perc 0}<= 60}´ëü ${else}${if_match ${smapi_bat_perc 0}<= 79}´ëÇ ${else}${if_match ${smapi_bat_perc 0}==80}´âž ${endif}${endif}${endif}${endif}${endif}${endif}${endif}${exec printf "%i" $(echo "$(cat /sys/devices/platform/smapi/BAT0/remaining_percent)*1.25" | bc)}% ${format_time ${battery_time} "\(\h:\m\)"}",
       "color" : "${if_match ${smapi_bat_perc 0}> 20}\#A6E22E"${else}\#F92672"${endif}
 },

 { "full_text" : "${time %d-%m-%Y  %H:%M}",
       "color" : "\#F8F8F2"
 }
],
